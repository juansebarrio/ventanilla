{
  "name": "ventanilla",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:local": "bash scripts/db-local.sh all",
    "db:verify": "bash scripts/db-local.sh verify",
    "db:down": "bash scripts/db-local.sh down",
    "db:reset": "bash scripts/db-local.sh reset",
    "db:types": "supabase gen types typescript --db-url postgresql://postgres@127.0.0.1:54322/ventanilla --schema public > lib/supabase/database.types.ts",
    "seed:remote": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env scripts/seed-remote.ts",
    "seed:foto": "tsx scripts/generar-foto-seed.ts",
    "seed:audio": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env scripts/generar-audio-seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.1",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jpeg-js": "^0.4.4",
    "supabase": "^2.109.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
