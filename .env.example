# ── Obligatorias (aplicación) ────────────────────────────────────────────────

# URL y anon key del proyecto Supabase (Dashboard → Settings → API).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role: SOLO server (route handlers / lib/supabase/admin.ts).
# Jamás exponerla con prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Clasificación y redacción (tanda 3). Sin la clave, el sistema degrada al
# clasificador por palabras y la respuesta al vecino es idéntica.
ANTHROPIC_API_KEY=

# Autoriza POST /api/demo/reset (reset diario del tenant demo, tanda 5).
DEMO_RESET_SECRET=

# ── Opcionales (degradan con elegancia si faltan) ───────────────────────────

# Síntesis del audio seed de Marta (tanda 5). Sin clave, el player del
# detalle queda en modo simulado, como el prototipo.
ELEVENLABS_API_KEY=

# WhatsApp Cloud API (tanda 6). Sin estas tres, el webhook responde 200 y
# no hace nada; la demo no depende de WhatsApp.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# App secret de la app de Meta, para validar la firma X-Hub-Signature-256
# del webhook. Opcional: sin este valor el webhook acepta sin validar.
WHATSAPP_APP_SECRET=

# Cap global diario del simulador público. Superado, se sigue atendiendo
# con el clasificador por palabras, sin avisar nada distinto al visitante.
SIMULATOR_DAILY_CAP=300

# URL pública canónica (para la metadata y la OG image). En Vercel, si falta,
# se usa VERCEL_URL; en local, http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://ventanilla.js80.studio

# Demo pública: con esta variable el login viene precargado con la usuaria
# de demostración (poné el mismo valor que SEED_ADMIN_PASSWORD). Es
# deliberadamente pública: el tenant es ficticio y se resetea a diario.
# Sin la variable, el login queda vacío como cualquier login normal.
NEXT_PUBLIC_DEMO_PASSWORD=
NEXT_PUBLIC_DEMO_EMAIL=carla@iribarne.ar

# Voz de ElevenLabs para el audio seed (scripts/generar-audio-seed.ts).
ELEVENLABS_VOICE_ID=

# ── Solo scripts (no las lee la aplicación) ─────────────────────────────────

# Cadena postgres:// del proyecto real (Dashboard → Settings → Database),
# para aplicar migraciones y seed.sql con psql.
SUPABASE_DB_URL=

# Usuaria del panel demo que crea scripts/seed-remote.ts.
SEED_ADMIN_EMAIL=carla@iribarne.ar
SEED_ADMIN_PASSWORD=
